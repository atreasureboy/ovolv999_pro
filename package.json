{
  "name": "ovogogogo",
  "version": "0.1.0",
  "description": "Lightweight OpenAI-compatible autonomous code execution engine",
  "type": "module",
  "main": "dist/bin/ovogogogo.js",
  "bin": {
    "ovogogogo": "./dist/bin/ovogogogo.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/bin/ovogogogo.js",
    "dev": "tsx bin/ovogogogo.ts",
    "lint": "eslint src/ bin/ tests/",
    "lint:fix": "eslint src/ bin/ --fix",
    "format": "prettier --write src/ bin/",
    "format:check": "prettier --check src/ bin/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "glob": "^11.0.0",
    "openai": "^4.77.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  }
}
